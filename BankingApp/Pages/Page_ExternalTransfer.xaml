<Page x:Class="BankingApp.Pages.Page_ExternalTransfer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BankingApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page_ExternalTransfer">

    <Grid Background="LightPink">
        <StackPanel Margin="20">

            <TextBlock Text="Перевод на другой счет" FontSize="24" FontWeight="Bold" Margin="0 0 0 20"/>

            <Grid Background="Beige" Margin="0 0 0 20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Баланс карты:" FontSize="14"/>
                <TextBlock Name="Text_Balance" Grid.Column="1" Text="23 737,50 ₽" FontSize="18" 
                           FontWeight="Bold" HorizontalAlignment="Right"/>
            </Grid>

            <Grid Margin="0 0 0 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <RadioButton Name="RadioButton_Phone" Grid.Column="0" Content="По телефону" IsChecked="True" Margin="0 0 5 0" 
                             FontSize="14" Background="Beige"/>

                <RadioButton Name="RadioButton_Card" Grid.Column="1" Content="По карте" Margin="5 0 0 0" 
                             FontSize="14" Background="Beige"/>
            </Grid>

            <Grid Margin="0 0 0 15" Name="PhonePanel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Name="Text_PhoneNumber"  Grid.Row="1" Text="Номер телефона" Height="45" 
                         FontSize="14" Background="Beige" Foreground="DimGray"/>
            </Grid>

            <Grid Margin="0 0 0 15" Name="CardPanel" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Name="Text_CardNumber"  Grid.Row="1" Height="45" Text="Номер карты" 
                         FontSize="14" Background="Beige" Foreground="DimGray"/>
            </Grid>

            <Grid Margin="0 0 0 15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Name="Text_TransferAmmount" Grid.Row="1" Height="45" Text="Сумма перевода" FontSize="14" Background="Beige" Foreground="DimGray"/>
            </Grid>

            <Grid Margin="0 0 0 15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBox Grid.Row="1" Height="45" Name="Text_MessageToRecipient" Text="Сообщение получателю" FontSize="14" Background="Beige" Foreground="DimGray"/>
            </Grid>

            <Button Content="Перевести" Height="50" Background="LightCoral"  FontSize="16" 
                    FontWeight="Bold" Margin="0 10 0 0" Click="ButtonClick_CommitExternalTransfer"/>

            <!--<TextBlock Margin="0 15 0 0" FontSize="14" TextWrapping="Wrap" HorizontalAlignment="Center"/>-->
        </StackPanel>
    </Grid>
</Page>
