<Page x:Class="BankingApp.Pages.Page_EnterPincode"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BankingApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="LightPink"
      Title="Page_EnterPincode">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250" MinWidth="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*" MinHeight="100"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <Border Background="LightCoral" Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"/>
            
            <Label Content="Здравствуйте!" Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="25"/>
            <Label Content="Введите пин-код:" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>

            <TextBox Grid.Row="2" Background="Beige"  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"  VerticalAlignment="Center"  Name="TB_pincode"/>
            <!--+ конвертер-->
            <!--<Label Content="..." Grid.Row="2"  HorizontalAlignment="Center" VerticalAlignment="Center" />-->
            
            <Button Content="  Ввести  "  Grid.Row="3" Background="LightCoral" Click="ButtonClick_CheckPincode" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="15" Margin="10"/>

        </Grid>
    </Grid>
</Page>
