<Page x:Class="BankingApp.Pages.Page_EnterPincode"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BankingApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="LightPink"
      Title="Page_EnterPincode">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition Height="*"/> <!--сделать рабочую область конкретной а не * или MinWidth="200"-->
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <Border Background="LightCoral" Grid.Row="1" Grid.Column="1"/>

        <Label Content="Здравствуйте!" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="25"/>
        <Label Content="Введите пин-код:" Grid.Column="1" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20"/>


        <Button Content="  Ввести  " Grid.Column="1" Grid.Row="2" Background="LightCoral" Click="ButtonClick_CheckPincode" HorizontalAlignment="Center" VerticalAlignment="Top" FontSize="15" Margin="10"/>

        <TextBox Text=".." Grid.Column="1" Grid.Row="1" Background="Beige"  HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"  VerticalAlignment="Bottom"  Name="TB_pincode"/>
    </Grid>
</Page>
