<Page x:Class="BankingApp.Pages.Page_InternalTransfer"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BankingApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page_InternalTransfer">

    <Grid Background="LightPink">
        <StackPanel Margin="20">
            <TextBlock Text="Перевод между своими счетами" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <Grid Background="Beige" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Баланс карты:" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Name="Text_CardBalance" Grid.Column="1" Text="0 ₽" FontSize="18" 
                           FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>

            <TextBlock Text="Откуда перевести" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox Name="Combo_FromAccount" Background="Beige" Height="45" Margin="0,0,0,15" FontSize="14">
                <ComboBoxItem Content="Карта"/>
                <ComboBoxItem Content="Накопительный счет"/>
            </ComboBox>

            <TextBlock Text="Куда перевести" FontSize="14" Margin="0,0,0,5"/>
            <ComboBox Name="Combo_ToAccount" Background="Beige" Height="45" Margin="0,0,0,15" FontSize="14">
                <ComboBoxItem Content="Накопительный счет"/>
                <ComboBoxItem Content="Карта"/>
            </ComboBox>

            <TextBlock Text="Сумма перевода" FontSize="14" Margin="0,0,0,5"/>
            <TextBox Name="Text_TransferAmount" Height="45" Background="Beige" FontSize="14" Margin="0,0,0,20"/>

            <Button Content="Перевести" Height="50" Background="LightCoral" FontSize="16" FontWeight="Bold"
                    Margin="0,0,0,15" Click="ButtonClick_CommitInternalTransfer"/>
            <TextBlock Name="Text_Message" FontSize="14" TextWrapping="Wrap" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
