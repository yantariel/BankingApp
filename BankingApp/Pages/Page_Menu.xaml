<Page x:Class="BankingApp.Pages.Page_Menu"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BankingApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800" Background="LightPink"
      Title="Page_Menu">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="50"/>  
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Добрый день" Grid.Column="0" Grid.Row="0" FontWeight="Bold" FontSize="20"
         HorizontalAlignment="Center" VerticalAlignment="Center"/>

        <TextBlock Text="$ 84.65       € 97.30       £ 126.45" Grid.Column="2" Grid.Row="2" FontSize="15"
         HorizontalAlignment="Center" VerticalAlignment="Top"/>


        <StackPanel Grid.Row="1" Margin="5 0 0 0">
            
            <Button Click="ButtonClick_ShowBalance" Background="LightCoral" Margin="0 5">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="138"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="   ₽   " Grid.Column="0" FontSize="30" Margin="0 20" HorizontalAlignment="Center"/>
                    <TextBlock Name="MenuCardBalance" Text="20 000.50 ₽" Grid.Column="1" Grid.Row="0"  VerticalAlignment="Center"
                               HorizontalAlignment="Left" FontSize="16" Margin="0 10 0 0"/>
                    <TextBlock Name="MenuSavingBalance" Text="3456 VISA" Grid.Column="1" Grid.Row="1"  VerticalAlignment="Center" 
                               HorizontalAlignment="Left" FontSize="13" Margin="0 0 0 10"/>
                </Grid>
            </Button>

            <Button Click="ButtonClick_ShowSavingAccount" Background="LightCoral" Margin="0 5">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="138"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="   ⬆️   " Grid.Column="0" FontSize="30" Margin="0 20" HorizontalAlignment="Center" />
                    <TextBlock Name="MenuSavingsBalance"  Text="0 ₽" Grid.Column="1" Grid.Row="0"  VerticalAlignment="Center" 
                               HorizontalAlignment="Left" FontSize="16" Margin="0 10 0 0"/>
                    <TextBlock Text="Накопительный счет" Grid.Column="1" Grid.Row="2"  VerticalAlignment="Center" 
                               HorizontalAlignment="Left" FontSize="13" Margin="0 0 0 10"/>
                </Grid>
            </Button>
        </StackPanel>

        <StackPanel  Grid.Row="1" Grid.Column="2" Orientation="Horizontal"  >

            <Button Click="ButtonClick_ExternalTransfer" Background="LightCoral" Width="130" Height="100" HorizontalContentAlignment="Left">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⛬" Grid.Row="0" FontSize="20" Margin="5 0 0 0"/>
                    <TextBlock Text="Перевести" Grid.Row="1" Margin="5 0 0 0"/>
                    <TextBlock Text="на другой счет" Grid.Row="2" Margin="5 0 0 0"/>
                </Grid>
            </Button>

            <Button Click="ButtonClick_InternalTransfer" Background="LightCoral" Width="130" Height="100" HorizontalContentAlignment="Left" Margin="10 0 0 0">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="⛖" Grid.Row="0" FontSize="20" Margin="5 0 0 0"/>
                    <TextBlock Text="Перевести" Grid.Row="1" Margin="5 0 0 0"/>
                    <TextBlock Text="между своими счетами" Grid.Row="2" Margin="5 0 0 0"/>
                </Grid>
            </Button>

            <Button Click="ButtonClick_Loan" Background="LightCoral" Width="130" Height="100" HorizontalContentAlignment="Left" Margin="10">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="✚" Grid.Row="0" FontSize="20" Margin="5 0 0 0"/>
                    <TextBlock Text="Взять" Grid.Row="1" Margin="5 0 0 0"/>
                    <TextBlock Text="кредит" Grid.Row="2" Margin="5 0 0 0"/>
                </Grid>
            </Button>

            <Button Click="ButtonClick_Bonus" Background="LightCoral" Width="130" Height="100" HorizontalContentAlignment="Left">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="7"/>
                    </Style>
                </Button.Resources>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="✪" Grid.Row="0" FontSize="20" Margin="5 0 0 0"/>
                    <TextBlock Text="Кешбек" Grid.Row="1" Margin="5 0 0 0"/>
                    <TextBlock Text="и бонусы" Grid.Row="2" Margin="5 0 0 0"/>
                </Grid>
            </Button>
        </StackPanel>
    </Grid>
</Page>
