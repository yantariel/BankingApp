<Page x:Class="BankingApp.Pages.Page_ShowBalance"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:BankingApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Page_ShowBalance">

    <Grid Background="LightCoral">
        <StackPanel Margin="20">
            <Grid Background="LightPink" Height="250" Margin="0,0,0,20">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Background="LightCoral" Width="40" Height="30" 
                          HorizontalAlignment="Left" Margin="0,0,0,10"/>

                    <TextBlock Name="Text_CardNumber" Grid.Row="1" Text="1234 5678 9012 3456" FontSize="20" 
                               FontWeight="Bold" VerticalAlignment="Center"/>

                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Срок:" FontSize="12" Margin="0,0,5,0"/>

                        <TextBlock Grid.Column="1" Text="12/28" FontSize="14" FontWeight="Bold" Margin="0,0,20,0"/>

                        <TextBlock Grid.Column="2" Text="CVV:" FontSize="12" Margin="0,0,5,0"/>

                        <TextBlock Grid.Column="3" Text="777" FontSize="14" FontWeight="Bold"/>
                    </Grid>

                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="YANA GUDKOVA" FontSize="12"/>

                        <TextBlock Grid.Column="1" Text="VISA" FontSize="16" FontWeight="Bold"/>
                    </Grid>
                </Grid>
            </Grid>

            <Grid Background="Beige" Height="100" Margin="0,0,0,15">

                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Баланс карты" FontSize="14"/>
                        <TextBlock Name="Text_CardBalance" Text="0 ₽" FontSize="24" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </StackPanel>
    </Grid>
</Page>
